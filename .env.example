# =============================================================================
# LLMOps Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Application -----------------------------------------------------------
APP_NAME="LLMOps Backend"

# --- LLM Providers (at least one required) ---------------------------------
# Google Gemini API key
GEMINI_API_KEY="your-gemini-api-key-here"

# Groq API key (default provider if LLM_PROVIDER is not set)
GROQ_API_KEY="your-groq-api-key-here"

# LLM provider selection: "groq" (default) or "gemini"
LLM_PROVIDER="groq"

# --- Vector Database (Qdrant) ----------------------------------------------
# URL for Qdrant vector database
QDRANT_URL="http://localhost:6333"

# Optional API key for Qdrant Cloud (leave empty for local Qdrant)
QDRANT_API_KEY=""

# --- API Authentication ----------------------------------------------------
# Optional API key for authenticating requests
# If empty, authentication is disabled
API_KEY="your-api-key-here"

# --- Observability: Langfuse (optional) ------------------------------------
# Langfuse public key for LLM tracing
LANGFUSE_PUBLIC_KEY=""

# Langfuse secret key
LANGFUSE_SECRET_KEY=""

# Langfuse host URL (default: https://cloud.langfuse.com)
LANGFUSE_HOST="https://cloud.langfuse.com"
